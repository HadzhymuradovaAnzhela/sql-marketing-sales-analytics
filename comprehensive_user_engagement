Comprehensive User Engagement and Email Analytics
/* SUMMARY: 
This query provides an end-to-end analysis of account growth and email engagement. 
By combining account metadata with messaging metrics, it identifies the most active geographical markets. 
The final result highlights the Top 10 countries based on both user base size and communication volume.

KEYS METRICS:
- Account Count
- Funnel Volumes
- Country Totals
- Performance Ranking

SQL METHODS:
- CTEs
- UNION ALL
- Window Functions
- DENSE_RANK (Top-10)
*/

WITH account_features AS (
  -- Collects account counts grouped by date, geography, and status
  SELECT
    s.date,
    sp.country,
    ac.send_interval,
    ac.is_verified,
    ac.is_unsubscribed,
    COUNT(DISTINCT ac.id) AS account_cnt
  FROM `DA.account` ac
  JOIN `DA.account_session` acs ON ac.id = acs.account_id
  JOIN `DA.session` s ON acs.ga_session_id = s.ga_session_id
  JOIN `DA.session_params` sp ON acs.ga_session_id = sp.ga_session_id
  GROUP BY 1, 2, 3, 4, 5
),
email_metric_base AS (
  -- Calculates raw interaction volumes per account
  SELECT
    es.id_account,
    COUNT(DISTINCT es.id_message) AS sent_msg,
    COUNT(DISTINCT eo.id_message) AS open_msg,
    COUNT(DISTINCT ev.id_message) AS visit_msg
  FROM `DA.email_sent` es
  LEFT JOIN `DA.email_open` eo ON es.id_message = eo.id_message
  LEFT JOIN `DA.email_visit` ev ON es.id_message = ev.id_message
  GROUP BY 1
)
email_metrics_detailed AS (
  -- Joins account attributes with email metrics for granular analysis
  SELECT
    ss.date,
    sp.country,
    a.send_interval,
    a.is_verified,
    a.is_unsubscribed,
    emb.sent_msg,
    emb.open_msg,
    emb.visit_msg
  FROM email_metric_base emb
  LEFT JOIN `DA.account` a ON emb.id_account = a.id
  JOIN `DA.account_session` s ON emb.id_account = s.account_id
  JOIN `DA.session` ss ON s.ga_session_id = ss.ga_session_id
  JOIN `DA.session_params` sp ON s.ga_session_id = sp.ga_session_id
),
union_data AS (
  -- Combines account counts and email metrics into a single dataset
  SELECT date, country, send_interval, is_verified, is_unsubscribed, account_cnt, 0 AS sent_msg, 0 AS open_msg, 0 AS visit_msg FROM account_features
  UNION ALL
  SELECT date, country, send_interval, is_verified, is_unsubscribed, 0 AS account_cnt, sent_msg, open_msg, visit_msg FROM email_metrics_detailed
),

aggregated_stats AS (
  -- Aggregates all values by date and primary dimensions
  SELECT
    date, country, send_interval, is_verified, is_unsubscribed,
    SUM(account_cnt) AS account_cnt,
    SUM(sent_msg) AS sent_msg,
    SUM(open_msg) AS open_msg,
    SUM(visit_msg) AS visit_msg
  FROM union_data
  GROUP BY 1, 2, 3, 4, 5
),
ranking_logic AS (
  -- Uses Window Functions to calculate totals and rank countries by performance
  SELECT
    *,
    SUM(account_cnt) OVER (PARTITION BY country) AS total_country_account_cnt,
    SUM(sent_msg) OVER (PARTITION BY country) AS total_country_sent_cnt,
    DENSE_RANK() OVER (ORDER BY SUM(account_cnt) OVER (PARTITION BY country) DESC) AS rank_accounts,
    DENSE_RANK() OVER (ORDER BY SUM(sent_msg) OVER (PARTITION BY country) DESC) AS rank_sent
  FROM aggregated_stats
)
-- Final output filtered to focus on Top 10 performing countries
SELECT * FROM ranking_logic
WHERE rank_accounts <= 10 AND rank_sent <= 10
ORDER BY date, country, send_interval, is_verified;
